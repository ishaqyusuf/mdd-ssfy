{
  "name": "nextjs-template",
  "devDependencies": {
    "@types/node": "^25.2.3",
    "check-dependency-version-consistency": "5.0.1",
    "dotenv-cli": "7.3.0",
    "knip": "^5.61.2"
  },
  "engines": {
    "node": ">=20.9.0"
  },
  "packageManager": "bun@1.3.9",
  "catalog": {
    "next": "^16.2.6",
    "pino": "^10.1.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "tailwindcss": "^4.1.17",
    "@tailwindcss/postcss": "^4.1.17",
    "typescript": "^5.9.3",
    "zod": "^4.3.5"
  },
  "private": true,
  "scripts": {
    "build": "turbo build ",
    "clean": "git clean -xdf node_modules",
    "clean:workspaces": "turbo clean",
    "db:docker:up": "docker compose -f apps/www/docker-compose.yml up -d mysql adminer",
    "db:docker:down": "docker compose -f apps/www/docker-compose.yml down",
    "db:docker:migrate": "bash ./scripts/mysql-xampp-to-docker.sh full",
    "db:push": "turbo -F @gnd/db push",
    "db:migrate": "turbo -F @gnd/db db-migrate",
    "db:generate": "bun run --filter @gnd/db db:generate",
    "db:update:local": "cd packages/db && bun run sync:prod-to-local",
    "db:update:local:dry-run": "cd packages/db && bun run sync:prod-to-local --dry-run",
    "db:update:local:reset": "cd packages/db && bun run sync:prod-to-local --reset-cursor",
    "db:sync:prod-to-local": "cd packages/db && bun run sync:prod-to-local",
    "db:sync:prod-to-local:dry-run": "cd packages/db && bun run sync:prod-to-local:dry-run",
    "db:sync:prod-to-local:table": "cd packages/db && bun run sync:prod-to-local:table",
    "control:parity-report": "node ./scripts/sales-control-parity-report.mjs",
    "payment:reconciliation-report": "bun ./scripts/payment-system-reconciliation-report.mjs",
    "test:new-sales-form-migration": "node ./scripts/new-sales-form-migration-tests.mjs",
    "backlog": "turbo dev --parallel  --filter @gnd/gnd-backlog",
    "mobile": "turbo dev --parallel  --filter @gnd/expo-app --filter @gnd/www",
    "mobile-jobs": "turbo dev --parallel  --filter @gnd/expo-app --filter @gnd/www --filter @gnd/site --filter @gnd/jobs",
    "mobile-jobs:terminal": "bun run terminal mobile-jobs",
    "terminal": "bash ./scripts/open-bun-script-terminal.sh",
    "kill:ports": "for port in 3000 3003 3004 3005 3006 3501 4100 4200 4300 5556; do lsof -ti tcp:$port | xargs kill -9 2>/dev/null || true; done",
    "dev": "turbo dev --parallel",
    "web": "turbo dev --parallel --filter @gnd/web",
    "www": "turbo dev --parallel --filter @gnd/www",
    "dealership": "turbo dev --parallel --filter @gnd/dealership",
    "websites": "turbo dev --parallel --filter @gnd/dealership --filter @gnd/www --filter @gnd/jobs",
    "www:jobs": "turbo dev --parallel --filter @gnd/www --filter @gnd/jobs",
    "jobs": "turbo dev --parallel --filter @gnd/jobs",
    "jobs:deploy": "bun run --filter @gnd/jobs deploy",
    "www:jobs-email": "turbo dev --parallel --filter @gnd/www --filter @gnd/jobs --filter @gnd/email",
    "www:prod": "turbo dev:prod --parallel --filter @gnd/www --filter @gnd/api",
    "build:preview": "bun ./scripts/eas-account-runner.ts build:preview",
    "update:preview": "bun ./scripts/eas-account-runner.ts update:preview",
    "format": "biome format --write .",
    "lint": "turbo lint && manypkg check",
    "---format": "turbo format --continue -- --cache --cache-location='node_modules/.cache/.prettiercache' --ignore-path='../../.gitignore'",
    "---format:fix": "turbo format --continue -- --write --cache --cache-location='node_modules/.cache/.prettiercache' --ignore-path='../../.gitignore'",
    "---lint": "turbo lint -- --quiet -- --cache --cache-location 'node_modules/.cache/.eslintcache' && manypkg check",
    "lint:fix": "turbo lint --continue -- --fix --cache --cache-location 'node_modules/.cache/.eslintcache' ",
    "typecheck": "turbo typecheck",
    "--postinstall": "bun run check-deps",
    "check-deps": "check-dependency-version-consistency .",
    "gen": "turbo gen --config 'turbo/generators/config.ts'",
    "knip": "knip"
  },
  "overrides": {
    "lightningcss": "1.30.1"
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "tooling/*"
  ],
  "dependencies": {
    "@biomejs/biome": "1.9.4",
    "@manypkg/cli": "^0.24.0",
    "bcrypt-ts": "^5.0.3",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dayjs": "^1.11.18",
    "dot-object": "^2.1.5",
    "framer-motion": "^12.23.24",
    "nanoid": "^5.1.5",
    "react-intersection-observer": "^9.16.0",
    "react-markdown": "^10.1.0",
    "react-responsive": "^10.0.1",
    "slugify": "^1.6.6",
    "superjson": "2.2.1",
    "tailwind-merge": "^3.3.1",
    "turbo": "2.5.8",
    "typescript": "^5.9.3"
  }
}
