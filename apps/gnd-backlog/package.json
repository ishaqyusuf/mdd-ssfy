{
  "name": "@gnd/gnd-backlog",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "contentlayer2 build && bun with-env next build",
    "clean": "git clean -xdf .next .turbo node_modules",
    "dev": "PORTLESS_APP_PORT=${PORTLESS_APP_PORT:-4200} bun with-env portless gnd-backlog next dev --turbopack",
    "lint": " bun with-env next lint --quiet",
    "format": "prettier --write '**/*.{js,cjs,mjs,ts,tsx,md,json}'  --ignore-path .prettierignore",
    "start": "bun with-env next start",
    "with-env": "dotenv -e ../../.env.local --"
  },
  "dependencies": {
    "@gnd/api": "workspace:*",
    "@gnd/ui": "workspace:*",
    "@gnd/utils": "workspace:*",
    "@hookform/resolvers": "^5.2.2",
    "@next/mdx": "15.3.2",
    "@t3-oss/env-nextjs": "0.8.0",
    "@tanstack/react-query": "^5.59.20",
    "@tanstack/react-query-devtools": "^5.59.20",
    "@tanstack/react-table": "^8.20.5",
    "@trpc/client": "^11.2.0",
    "@trpc/server": "^11.2.0",
    "@trpc/tanstack-react-query": "^11.2.0",
    "date-fns": "3.3.1",
    "next": "15.5.5",
    "nuqs": "^2.4.3",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-hook-form": "^7.66.0",
    "server-only": "^0.0.1",
    "superjson": "2.2.1",
    "zod": "catalog:",
    "zustand": "^5.0.0-rc.2"
  },
  "devDependencies": {
    "@types/node": "^25.2.3",
    "@types/react": "~19.1.0",
    "@types/react-dom": "^19.1.9",
    "dotenv-cli": "7.3.0",
    "prettier": "3.2.5",
    "tailwindcss": "^4.1.17",
    "typescript": "^5.9.3",
    "contentlayer2": "0.4.6",
    "@next-devtools/core": "0.2.0"
  },
  "eslintConfig": {
    "root": true
  }
}
