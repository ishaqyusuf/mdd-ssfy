{
	"name": "@gnd/dealership",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"with-env": "bun ../../../../local-infra-kit/bin/with-env.ts --profile gnd --",
		"with-env:prod": "bun ../../../../local-infra-kit/bin/with-env.ts --profile gnd --mode prod --",
		"dev": "bun run with-env env PORTLESS_PORT=${GND_PROXY_PORT:-443} PORTLESS_WILDCARD=${PORTLESS_WILDCARD:-1} PORTLESS_SYNC_HOSTS=${PORTLESS_SYNC_HOSTS:-0} PORTLESS_APP_PORT=${PORTLESS_APP_PORT:-${GND_DEALERSHIP_PORT:-3016}} TZ=UTC portless gnd-dealership next dev --turbopack",
		"clean": "git clean -xdf .next .turbo node_modules",
		"build": "bun run with-env:prod env next build --turbopack",
		"start": "next start",
		"lint": "next lint",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@gnd/api": "workspace:*",
		"@gnd/auth": "workspace:*",
		"@gnd/community": "workspace:*",
		"@gnd/db": "workspace:*",
		"@gnd/events": "workspace:*",
		"@gnd/notifications": "workspace:*",
		"@gnd/sales": "workspace:*",
		"@gnd/site-nav": "workspace:*",
		"@gnd/ui": "workspace:*",
		"@gnd/utils": "workspace:*",
		"@faker-js/faker": "^10.1.0",
		"@hookform/resolvers": "^5.2.2",
		"@tanstack/react-query": "^5.90.3",
		"@tanstack/react-table": "^8.21.3",
		"@trigger.dev/sdk": "3.3.17",
		"@trpc/client": "^11.6.0",
		"@trpc/server": "^11.6.0",
		"@trpc/tanstack-react-query": "^11.6.0",
		"better-auth": "^1.4.0",
		"lucide-react": "^0.546.0",
		"next": "catalog:",
		"next-themes": "^0.4.6",
		"nuqs": "^2.7.1",
		"react": "catalog:",
		"react-dom": "catalog:",
		"react-hook-form": "^7.66.0",
		"react-number-format": "^5.4.4",
		"superjson": "2.2.2",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@gnd/tsconfig": "workspace:*",
		"@tailwindcss/postcss": "catalog:",
		"@types/node": "^25.2.3",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"tailwindcss": "catalog:",
		"typescript": "catalog:"
	}
}
