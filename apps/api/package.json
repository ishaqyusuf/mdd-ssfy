{
  "name": "@gnd/api",
  "scripts": {
    "dev": "TZ=UTC PORT=3004 bun run --hot src/index.ts",
    "dev:node": "tsx src/node.ts",
    "--build": "bun-vercel ./src/bun.ts",
    "-build": "./bun-vercel/build.sh ./src/bun.ts",
    "deploy:vc": "vc",
    "start": "node ./dist/src/index.js",
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:watch": "bun test --watch"
  },
  "exports": {
    "./trpc/routers/_app": "./src/trpc/routers/_app.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.4",
    "@hono/trpc-server": "^0.3.4",
    "@hono/zod-openapi": "^0.19.8",
    "@gnd/auth": "workspace:*",
    "@gnd/community": "workspace:*",
    "@gnd/db": "workspace:*",
    "@gnd/dev-logger": "workspace:*",
    "@gnd/documents": "workspace:*",
    "@gnd/utils": "workspace:*",
    "@gnd/jobs": "workspace:*",
    "@gnd/notifications": "workspace:*",
    "@gnd/sales": "workspace:*",
    "@gnd/settings": "workspace:*",
    "@gnd/square": "workspace:*",
    "@trigger.dev/sdk": "3.3.17",
    "@trpc/server": "^11.4.1",
    "@vercel/blob": "^1.1.1",
    "date-fns": "^4.1.0",
    "hono": "^4.7.11",
    "jsonwebtoken": "^9.0.3",
    "lodash": "^4.17.21",
    "lru-cache": "^11.1.0",
    "superjson": "^2.2.2",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/bun": "^1.2.17",
    "@types/jsonwebtoken": "^9.0.10",
    "vercel": "^44.2.7"
  }
}
