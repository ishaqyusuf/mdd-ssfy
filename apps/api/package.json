{
	"name": "@gnd/api",
	"scripts": {
		"--build": "bun run with-env:prod bun-vercel ./src/bun.ts",
		"-build": "./bun-vercel/build.sh ./src/bun.ts",
		"deploy:vc": "vc",
		"dev": "bun run with-env env TZ=UTC PORT=3014 bun run --hot src/index.ts",
		"dev:node": "bun run with-env tsx src/node.ts",
		"format": "biome format --write .",
		"lint": "biome check .",
		"start": "node ./dist/src/index.js",
		"storefront:seed-test-catalog": "bun run with-env bun scripts/seed-storefront-test-catalog.ts",
		"test": "bun test",
		"test:watch": "bun test --watch",
		"typecheck": "tsc --noEmit",
		"with-env": "bun ../../../../local-infra-kit/bin/with-env.ts --profile gnd --",
		"with-env:prod": "bun ../../../../local-infra-kit/bin/with-env.ts --profile gnd --mode prod --"
	},
	"exports": {
		"./trpc/routers/_app": "./src/trpc/routers/_app.ts",
		"./trpc/routers/dealership-app": "./src/trpc/routers/dealership-app.ts",
		"./trpc/routers/storefront-app": "./src/trpc/routers/storefront-app.ts",
		"./db/queries/task-run-diagnostics": "./src/db/queries/task-run-diagnostics.ts",
		"./db/queries/customer-statement-print": "./src/db/queries/customer-statement-print.ts",
		"./utils/sales-document-access": "./src/utils/sales-document-access.ts",
		"./utils/sales-document-snapshot-policy": "./src/utils/sales-document-snapshot-policy.ts",
		"./utils/sales-document-warm": "./src/utils/sales-document-warm.ts"
	},
	"dependencies": {
		"@date-fns/utc": "^2.1.0",
		"@hono/node-server": "^1.14.4",
		"@hono/trpc-server": "^0.3.4",
		"@hono/zod-openapi": "^0.19.8",
		"@hono/zod-validator": "^0.7.0",
		"@scalar/hono-api-reference": "^0.9.1",
		"@gnd/auth": "workspace:*",
		"@gnd/cache": "workspace:*",
		"@gnd/community": "workspace:*",
		"@gnd/db": "workspace:*",
		"@gnd/dev-logger": "workspace:*",
		"@gnd/documents": "workspace:*",
		"@gnd/inventory": "workspace:*",
		"@gnd/logger": "workspace:*",
		"@gnd/utils": "workspace:*",
		"@gnd/jobs": "workspace:*",
		"@gnd/notifications": "workspace:*",
		"@gnd/pdf": "workspace:*",
		"@gnd/sales": "workspace:*",
		"@gnd/settings": "workspace:*",
		"@gnd/square": "workspace:*",
		"@sindresorhus/slugify": "^2.2.1",
		"@trigger.dev/sdk": "3.3.17",
		"@trpc/server": "^11.4.1",
		"@vercel/blob": "^2.3.0",
		"bun-vercel": "^1.0.0-alpha.5",
		"camelcase-keys": "^9.1.3",
		"date-fns": "^4.1.0",
		"hono": "^4.7.11",
		"hono-rate-limiter": "^0.4.2",
		"jose": "^6.0.11",
		"jsonwebtoken": "^9.0.3",
		"lodash": "^4.17.21",
		"lru-cache": "^11.1.0",
		"nanoid": "^5.1.5",
		"pino": "^9.7.0",
		"postgres": "^3.4.7",
		"resend": "^4.5.1",
		"snakecase-keys": "^8.0.1",
		"superjson": "^2.2.2",
		"uuid": "^11.1.0",
		"zod": "catalog:",
		"zod-openapi": "^4.2.4"
	},
	"devDependencies": {
		"@types/bun": "^1.2.17",
		"@types/jsonwebtoken": "^9.0.10",
		"vercel": "^44.2.7"
	}
}
