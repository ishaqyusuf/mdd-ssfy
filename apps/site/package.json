{
  "name": "@gnd/site",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "PORTLESS_APP_PORT=${PORTLESS_APP_PORT:-4100} TZ=UTC portless gnd-site next dev --turbopack",
    "clean": "git clean -xdf .next .turbo node_modules",
    "build": "NODE_ENV=production next build --turbopack",
