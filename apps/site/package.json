    "@radix-ui/react-slot": "^1.1.2",
    "@tanstack/react-query": "^5.80.7",
    "@trpc/client": "^11.4.1",
    "@trpc/tanstack-react-query": "^11.4.1",
    "@trpc/server": "^11.2.0",
    "clsx": "^2.1.1",
    "framer-motion": "^12.18.1",
    "nanoid": "^5.1.2",
    "next": "15.5.5",
    "next-auth": "^4.24.4",
    "nuqs": "^2.4.3",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-hook-form": "^7.66.0",
    "sass": "^1.71.1",
