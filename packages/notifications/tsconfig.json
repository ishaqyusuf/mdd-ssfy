{
  "extends": "@gnd/tsconfig/base.json",
  "include": ["src", "../../types"],
  "exclude": ["node_modules"],
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "noImplicitAny": false,
    "baseUrl": ".",
    "paths": {
      "@emails/*": ["../email/emails/*"],
      "@gnd/sales": ["../sales/src/exports.ts"],
      "@sales/*": ["../sales/src/*"],
      "@gnd/sales/*": ["../sales/src/*"],
      "@gnd/app-store/whatsapp-client": [
        "../app-store/src/whatsapp/server/client.ts"
      ]
      // "@sales/*": ["../sales/src/*"]
      // "@/*": ["./src/*"],
      // "@api/*": ["../../apps/api/src/*"]
    }
  }
