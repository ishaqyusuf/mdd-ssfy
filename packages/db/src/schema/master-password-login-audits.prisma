enum MasterPasswordLoginPlatform {
    WEBSITE
    MOBILE
    UNKNOWN
}

enum MasterPasswordUsageType {
    LOGIN
    SALES_REP_TRANSFER
}

model MasterPasswordLoginAudit {
    id                    String                      @id @default(cuid())
    targetUserId          Int?
    targetUserName        String?                     @db.VarChar(255)
    targetUserEmail       String?                     @db.VarChar(255)
    appSurface            String                      @default("www") @db.VarChar(40)
    usageType             MasterPasswordUsageType     @default(LOGIN)
    platform              MasterPasswordLoginPlatform @default(UNKNOWN)
    ipAddress             String?                     @db.VarChar(255)
    countryCode           String?                     @db.VarChar(2)
    browser               String?                     @db.VarChar(255)
    userAgent             String?                     @db.Text
    sessionId             String?                     @db.VarChar(255)
    requestId             String?                     @db.VarChar(255)
    resourceType          String?                     @db.VarChar(40)
    resourceId            String?                     @db.VarChar(255)
    loginAt               DateTime                    @default(now()) @db.Timestamp(0)
    clearedAt             DateTime?                   @db.Timestamp(0)
    clearedBySuperAdminId Int?
    createdAt             DateTime?                   @default(now()) @db.Timestamp(0)
    updatedAt             DateTime?                   @updatedAt
    deletedAt             DateTime?                   @db.Timestamp(0)
    targetUser            Users?                      @relation(name: "masterPasswordLoginAuditTarget", fields: [targetUserId], references: [id])
    clearedBySuperAdmin   Users?                      @relation(name: "masterPasswordLoginAuditClearedBy", fields: [clearedBySuperAdminId], references: [id])

    @@index([clearedAt, loginAt])
    @@index([targetUserId, loginAt])
    @@index([usageType, loginAt])
    @@index([platform, loginAt])
    @@index([resourceType, resourceId])
    @@index([sessionId])
    @@index([deletedAt])
}
