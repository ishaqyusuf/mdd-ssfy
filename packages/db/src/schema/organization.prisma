model Organization {
    id      Int      @unique @default(autoincrement())
    name    String
    primary Boolean?
    address String?

    createdAt DateTime? @default(now()) @db.Timestamp(0)
    updatedAt DateTime? @updatedAt
    deletedAt DateTime? @db.Timestamp(0)

    projects     Projects[]
    homes        Homes[]
    sales        SalesOrders[]
    userProfiles ModelHasRoles[]
    workOrders   WorkOrders[]
}
