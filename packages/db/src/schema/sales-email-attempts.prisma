enum SalesEmailAttemptStatus {
    QUEUED
    SENDING
    SENT
    FAILED
    SKIPPED
}

model SalesEmailAttempt {
    id                String                  @id @default(cuid())
    status            SalesEmailAttemptStatus @default(QUEUED)
    emailKind         String                  @db.VarChar(80)
    documentType      String?                 @db.VarChar(50)
    emailType         String?                 @db.VarChar(100)
    subject           String?                 @db.VarChar(500)
    message           String?                 @db.Text
    recipientEmail    String?                 @db.VarChar(255)
    customerName      String?                 @db.VarChar(255)
    customerEmail     String?                 @db.VarChar(255)
    senderId          Int?
    salesRepId        Int?
    provider          String?                 @db.VarChar(50)
    providerMessageId String?                 @db.VarChar(255)
    providerStatus    String?                 @db.VarChar(100)
    taskRunId         String?                 @db.VarChar(255)
    errorCode         String?                 @db.VarChar(255)
    errorMessage      String?                 @db.Text
    salesIds          Json?                   @db.Json
    salesNos          Json?                   @db.Json
    salesIdsText      String?                 @db.VarChar(1000)
    salesNosText      String?                 @db.VarChar(1000)
    metadata          Json?                   @db.Json
    originalAttemptId String?
    sentAt            DateTime?               @db.Timestamp(0)
    failedAt          DateTime?               @db.Timestamp(0)
    skippedAt         DateTime?               @db.Timestamp(0)
    createdAt         DateTime?               @default(now()) @db.Timestamp(0)
    updatedAt         DateTime?               @updatedAt
    deletedAt         DateTime?               @db.Timestamp(0)
    sender            Users?                  @relation(name: "salesEmailAttemptSender", fields: [senderId], references: [id])
    salesRep          Users?                  @relation(name: "salesEmailAttemptSalesRep", fields: [salesRepId], references: [id])
    originalAttempt   SalesEmailAttempt?      @relation("SalesEmailAttemptRetry", fields: [originalAttemptId], references: [id], onDelete: NoAction, onUpdate: NoAction)
    retryAttempts     SalesEmailAttempt[]     @relation("SalesEmailAttemptRetry")

    @@index([status, createdAt])
    @@index([senderId, createdAt])
    @@index([salesRepId, createdAt])
    @@index([recipientEmail])
    @@index([originalAttemptId])
    @@index([taskRunId])
    @@index([deletedAt])
}
