{
  "name": "@gnd/site-nav",
  "version": "1.0.0",
  "private": true,
  "sideEffects": false,
  "typesVersions": {
    "*": {
      "*": [
        "src/*"
      ]
    }
  },
  "scripts": {
    "clean": "rm -rf .turbo node_modules",
    "format": "biome --write .",
    "lint": "biome check .",
    "typecheck": "tsc --noEmit"
  },
  "exports": {
    ".": "./src/index.tsx",
    "./types": "./src/lib/types.ts",
    "./access": "./src/lib/access.ts",
    "./links": "./src/lib/links.ts",
    "./*": "./src/utils/*.tsx"
  },
  "dependencies": {
    "@gnd/ui": "workspace:*",
    "@gnd/utils": "workspace:*"
  },
  "devDependencies": {
    "@gnd/tsconfig": "workspace:*",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "typescript": "^5.9.2"
  }
}
