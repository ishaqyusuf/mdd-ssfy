{
  "name": "@gnd/jobs",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "clean": "rm -rf .turbo node_modules",
    "deploy": "bun run prisma.ts && bun run with-env:prod bun ../../scripts/with-trigger-profile.mjs -- trigger deploy",
    "dev": "bun run with-env bun ../../scripts/with-trigger-profile.mjs -- trigger dev --profile redland",
    "typecheck": "tsc --noEmit",
    "with-env": "bun ../../../../local-infra-kit/bin/with-env.ts --profile gnd --",
    "with-env:prod": "bun ../../../../local-infra-kit/bin/with-env.ts --profile gnd --mode prod --"
  },
  "exports": {
    "./schema": "./src/schema.ts",
    "./task-events/registry": "./src/task-events/registry.ts"
  },
  "dependencies": {
    "@fast-csv/format": "5.0.2",
    "@gnd/db": "workspace:*",
    "@gnd/auth": "workspace:*",
    "@gnd/documents": "workspace:*",
    "@gnd/inventory": "workspace:*",
    "@gnd/utils": "workspace:*",
    "@gnd/notifications": "workspace:*",
    "@gnd/community": "workspace:*",
    "@gnd/pdf": "workspace:*",
    "@gnd/sales": "workspace:*",
    "@gnd/settings": "workspace:*",
    "@sindresorhus/slugify": "^2.2.1",
    "@gnd/email": "workspace:*",
    "@trigger.dev/sdk": "4.0.1",
    "@trigger.dev/build": "4.0.1",
    "@trigger.dev/core": "4.0.1",
    "@zip.js/zip.js": "^2.7.62",
    "camelcase-keys": "^9.1.3",
    "resend": "^4.8.0",
    "heic-convert": "1.2.4",
    "node-xlsx": "^0.24.0",
    "qs": "^6.14.0",
    "@prisma/client": "^6.18.0",
    "@prisma/instrumentation": "^6.18.0",
    "@vercel/blob": "^2.3.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@gnd/tsconfig": "workspace:*",
    "@types/bun": "^1.2.17",
    "@types/heic-convert": "2.1.0",
    "@types/qs": "^6.14.0",
    "trigger.dev": "4.0.1"
  }
}
