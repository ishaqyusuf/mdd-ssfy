{
  "extends": "@gnd/tsconfig/base.json",
  "include": ["src", "../../types"],
  "exclude": ["node_modules"],
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noImplicitAny": false,
    "types": ["node", "bun"],
    "typeRoots": ["./node_modules/@types", "../../node_modules/@types", "../../types"],
    "baseUrl": ".",
    "paths": {
      "@jobs/*": ["src/*"],
      "@sales/*": ["../sales/src/*"],
      "@gnd/sales/*": ["../sales/src/*"],
      "@gnd/settings": ["../settings/src/index.ts"],
      "@emails/*": ["../email/src/*"],
      "@utils/*": ["../utils/src/*"],
      "@notifications/*": ["../notifications/src/*"],
      "@community/*": ["../community/src/*"],
      "@api/*": ["../apps/api/src/*"]
    },
    "jsx": "react-jsx"
  }
}
