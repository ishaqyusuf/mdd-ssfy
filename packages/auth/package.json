{
  "name": "@gnd/auth",
  "version": "1.0.0",
  "private": true,
  "exports": {
    ".": "./src/index.ts",
    "./utils": "./src/utils.ts"
  },
  "prisma": {
    "schema": "./src/schema"
  },
  "scripts": {
    "clean": "rm -rf .turbo node_modules",
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "with-env": "dotenv -e ../../.env --"
  },
  "dependencies": {
    "@gnd/db": "workspace:*",
    "@gnd/utils": "workspace:*",
    "@next-auth/prisma-adapter": "^1.0.7",
    "next-auth": "^4.24.11"
  },
  "devDependencies": {
    "@gnd/tsconfig": "workspace:*",
    "react": "catalog:",
    "react-dom": "catalog:",
    "typescript": "^5.9.3"
  }
}
